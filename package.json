{
  "name": "orbit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "compose:down": "docker compose down --remove-orphans",
    "compose:up": "docker compose up --build",
    "dev:local": "bash infra/scripts/dev-up.sh",
    "db:migration:revert": "pnpm --filter @orbit/api migration:revert",
    "db:migration:run": "pnpm --filter @orbit/api migration:run",
    "demo:coaching:reset": "pnpm --filter @orbit/api demo:coaching:reset",
    "env:sync:stg": "node infra/scripts/sync-personal-staging-doppler.mjs",
    "env:sync:stg:apply": "node infra/scripts/sync-personal-staging-doppler.mjs --apply",
    "test:coaching:migrations": "bash infra/scripts/test-adaptive-coaching-migrations.sh",
    "test:coaching:integration": "bash infra/scripts/test-adaptive-coaching-integration.sh",
    "test:coaching:e2e": "pnpm --filter @orbit/shared build && pnpm --filter @orbit/editor-core build && pnpm test:smoke --grep \"adaptive coaching\"",
    "test:coaching:python": "cd services/python-worker && uv sync --locked && uv run ruff check . && uv run mypy app && uv run pytest",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "py:sync": "cd services/python-worker && uv sync",
    "py:test": "cd services/python-worker && uv run pytest",
    "test": "turbo run test",
    "test:activity-slides:e2e": "node infra/scripts/run-playwright-test.mjs activity-slides.spec.ts",
    "test:env-contract": "node --test infra/scripts/personal-staging-env.test.mjs",
    "test:nli-browser": "node infra/scripts/run-semantic-cue-nli-browser-benchmark.mjs",
    "test:smoke": "node infra/scripts/run-playwright-test.mjs",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@orbit/editor-core": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "axe-core": "4.10.3",
    "pg": "^8.22.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
