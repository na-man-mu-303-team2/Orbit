{
  "name": "orbit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "compose:down": "docker compose down --remove-orphans",
    "compose:up": "docker compose up --build",
    "db:migration:revert": "pnpm --filter @orbit/api migration:revert",
    "db:migration:run": "pnpm --filter @orbit/api migration:run",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "py:sync": "cd services/python-worker && uv sync",
    "py:test": "cd services/python-worker && uv run pytest",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}

