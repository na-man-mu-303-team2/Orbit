{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ORBIT Codex Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "findings", "followUps"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "findings": {
      "type": "array",
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "category",
          "path",
          "line",
          "title",
          "body",
          "evidence"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocker", "high", "medium", "low", "note"]
          },
          "category": {
            "type": "string",
            "enum": [
              "security",
              "contract-api",
              "test-ci",
              "repo-rule",
              "migration-data",
              "runtime",
              "docs",
              "maintainability"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "line": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3000
          },
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": ["basis", "references"],
            "properties": {
              "basis": {
                "type": "array",
                "minItems": 1,
                "maxItems": 6,
                "items": {
                  "type": "string",
                  "enum": [
                    "file-line",
                    "repo-rule",
                    "contract-api",
                    "test-ci",
                    "risk",
                    "official-tech-doc"
                  ]
                }
              },
              "references": {
                "type": "array",
                "minItems": 1,
                "maxItems": 10,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 240
                }
              }
            }
          }
        }
      }
    },
    "followUps": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  }
}
