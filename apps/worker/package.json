{
  "name": "@orbit/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "clean": "rm -rf dist",
    "dev": "nest start --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "test": "corepack pnpm --filter @orbit/shared build && corepack pnpm --filter @orbit/editor-core build && corepack pnpm --filter @orbit/ai build && corepack pnpm --filter @orbit/config build && corepack pnpm --filter @orbit/storage build && corepack pnpm --filter @orbit/job-queue build && vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/typeorm": "^11.0.0",
    "@orbit/config": "workspace:*",
    "@orbit/editor-core": "workspace:*",
    "@orbit/ai": "workspace:*",
    "@orbit/job-queue": "workspace:*",
    "@orbit/shared": "workspace:*",
    "@orbit/storage": "workspace:*",
    "bullmq": "^5.56.0",
    "ioredis": "^5.6.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.16.2",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.25",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/node": "^24.0.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
