{
  "name": "@orbit/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "clean": "rm -rf dist",
    "dev": "nest start --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "migration:generate": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:generate",
    "migration:revert": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:revert",
    "migration:run": "typeorm-ts-node-commonjs -d src/database/data-source.ts migration:run",
    "start": "node dist/main.js",
    "test": "corepack pnpm --filter @orbit/shared build && corepack pnpm --filter @orbit/config build && vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.3",
    "@orbit/config": "workspace:*",
    "@orbit/editor-core": "workspace:*",
    "@orbit/job-queue": "workspace:*",
    "@orbit/realtime": "workspace:*",
    "@orbit/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "multer": "^2.0.1",
    "pg": "^8.16.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.25",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
