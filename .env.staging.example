NODE_ENV=production
APP_ENV=staging

WEB_PORT=5173
API_PORT=3000
API_JSON_BODY_LIMIT_BYTES=5000000
WORKER_PORT=3001
PYTHON_WORKER_PORT=8000

WEB_ORIGIN=https://staging.example.com
API_BASE_URL=https://api-staging.example.com
PYTHON_WORKER_URL=http://python-worker.internal:8000

DATABASE_URL=postgres://USER:PASSWORD@staging-rds.example.com:5432/orbit
REDIS_URL=rediss://staging-redis.example.com:6379
PRIVATE_EVIDENCE_REDIS_URL=rediss://staging-private-evidence-redis.example.com:6379
# Keep adaptive coaching disabled until the rollout is approved.
# To enable it, set all three flags to true and add comma-separated project IDs.
# Example: ADAPTIVE_COACHING_PROJECT_ALLOWLIST=project_a,project_b
ADAPTIVE_REHEARSAL_COACH_ENABLED=false
FOCUSED_PRACTICE_ENABLED=false
CHALLENGE_QNA_ENABLED=false
DEMO_COACHING_FIXTURE_ENABLED=false
DEMO_FIXTURE_ENV_ALLOWLIST=staging
ADAPTIVE_COACHING_PROJECT_ALLOWLIST=
COACHING_IDEMPOTENCY_HMAC_SECRET=replace-with-32-character-minimum-secret
COACHING_IDEMPOTENCY_HMAC_KEY_VERSION=1
COACHING_IDEMPOTENCY_HMAC_PREVIOUS_SECRET=
COACHING_IDEMPOTENCY_HMAC_PREVIOUS_KEY_VERSION=

SESSION_SECRET=replace-with-staging-session-secret
COOKIE_SECRET=replace-with-staging-cookie-secret

STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=https://orbit-staging-assets.example.com
S3_BUCKET=orbit-staging
S3_REGION=ap-northeast-2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

JOB_QUEUE_DRIVER=bullmq
LIVE_STT_PROVIDER=sherpa
LIVE_STT_ENGINE=web-speech
REPORT_STT_PROVIDER=openai
REHEARSAL_AUDIO_MAX_BYTES=25000000
OCR_PROVIDER=textract
LLM_PROVIDER=openai
AI_SLIDE_IMAGE_REVIEW_MODE=auto
ORBIT_PPTX_OOXML_VECTOR_IMPORT=true
VITE_SEMANTIC_CUE_NLI_ENABLED=false
VITE_SEMANTIC_CUE_NLI_PROVIDER=off
VITE_SEMANTIC_CUE_NLI_MODEL_ID=MoritzLaurer/multilingual-MiniLMv2-L6-mnli-xnli
VITE_SEMANTIC_CUE_NLI_BENCHMARK_PASSED=false
VITE_SEMANTIC_CUE_NLI_BENCHMARK_DEVICE=

OPENAI_API_KEY=replace-with-staging-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
AI_PPT_VISUAL_QA_MODEL=
OPENAI_IMAGE_MODEL=gpt-image-1
IMAGE_PROVIDER=openai
PUBLIC_IMAGE_PROVIDER=openverse
IMAGE_MAX_PER_DECK=4
IMAGE_MAX_PER_USER_PER_DAY=30
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_TRANSCRIPTION_DELAY=minimal
OPENAI_REALTIME_CLIENT_SECRET_TTL_SECONDS=600
WHISPERX_API_URL=
WHISPERX_API_KEY=
WHISPERX_MODEL=large-v3
WHISPERX_TIMEOUT_MS=30000

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TRANSCRIBE_LANGUAGE_CODE=ko-KR
TEXTRACT_ENABLED=true

# Keep true/empty for normal staging. Only set false for the temporary personal
# HTTP demo server, never for production.
AUTH_COOKIE_SECURE=
LOG_LEVEL=info
LOG_PRETTY=false

DEMO_USER_ID=user_demo_1
DEMO_WORKSPACE_ID=workspace_demo_1
DEMO_PROJECT_ID=project_demo_1
DEMO_DECK_ID=deck_demo_1
DEMO_SESSION_ID=session_demo_1
