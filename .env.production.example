# ORBIT production environment template.
# Keep this file free of real secrets. Copy the keys into the deployment
# platform secret store and replace placeholder values there.

NODE_ENV=production
APP_ENV=production

WEB_PORT=5173
API_PORT=3000
WORKER_PORT=3001
PYTHON_WORKER_PORT=8000

WEB_ORIGIN=https://app.example.com
API_BASE_URL=https://api.example.com
PYTHON_WORKER_URL=http://python-worker.internal:8000

DATABASE_URL=postgres://USER:PASSWORD@prod-rds.example.com:5432/orbit
REDIS_URL=rediss://prod-redis.example.com:6379

SESSION_SECRET=replace-with-production-session-secret
COOKIE_SECRET=replace-with-production-cookie-secret

STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=https://assets.example.com
S3_BUCKET=orbit-production
S3_REGION=ap-northeast-2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

JOB_QUEUE_DRIVER=sqs
STT_PROVIDER=transcribe
OCR_PROVIDER=textract
LLM_PROVIDER=openai

OPENAI_API_KEY=replace-with-production-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TRANSCRIBE_LANGUAGE_CODE=ko-KR
TEXTRACT_ENABLED=true

DEMO_USER_ID=user_demo_1
DEMO_WORKSPACE_ID=workspace_demo_1
DEMO_PROJECT_ID=project_demo_1
DEMO_DECK_ID=deck_demo_1
DEMO_SESSION_ID=session_demo_1
