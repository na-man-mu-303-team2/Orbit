# ORBIT local development environment.
# Copy this file to .env.local before running apps or docker compose locally.
# For staging/production, keep the same keys but use .env.staging.example or
# .env.production.example as the value guide. Do not reuse localhost or local
# demo secrets outside APP_ENV=local/test.

NODE_ENV=development
APP_ENV=local

WEB_PORT=5173
API_PORT=3000
API_JSON_BODY_LIMIT_BYTES=5000000
WORKER_PORT=3001
PYTHON_WORKER_PORT=8000

WEB_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:3000
PYTHON_WORKER_URL=http://localhost:8000

DATABASE_URL=postgres://orbit:orbit@localhost:5432/orbit
REDIS_URL=redis://localhost:6379
PRIVATE_EVIDENCE_REDIS_URL=redis://localhost:6380
# Adaptive coaching is enabled for every local project by default.
# Replace "*" with comma-separated project IDs to test a limited rollout.
ADAPTIVE_REHEARSAL_COACH_ENABLED=true
FOCUSED_PRACTICE_ENABLED=true
CHALLENGE_QNA_ENABLED=true
DEMO_COACHING_FIXTURE_ENABLED=true
DEMO_FIXTURE_ENV_ALLOWLIST=local,test
ADAPTIVE_COACHING_PROJECT_ALLOWLIST=*
COACHING_IDEMPOTENCY_HMAC_SECRET=local-coaching-idempotency-secret-change-me
COACHING_IDEMPOTENCY_HMAC_KEY_VERSION=1
COACHING_IDEMPOTENCY_HMAC_PREVIOUS_SECRET=
COACHING_IDEMPOTENCY_HMAC_PREVIOUS_KEY_VERSION=

SESSION_SECRET=local-session-secret-change-me
COOKIE_SECRET=local-cookie-secret-change-me

STORAGE_DRIVER=minio
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=orbit-local
S3_REGION=ap-northeast-2
S3_ACCESS_KEY_ID=orbit
S3_SECRET_ACCESS_KEY=orbit-password
S3_FORCE_PATH_STYLE=true

JOB_QUEUE_DRIVER=bullmq
AI_DECK_EXECUTION_MODE=bullmq
AI_DECK_WORKER_QUEUE=all
AI_DECK_SQS_REFERENCE_EXTRACT_QUEUE_URL=
AI_DECK_SQS_RESEARCH_CONTENT_QUEUE_URL=
AI_DECK_SQS_DESIGN_LAYOUT_QUEUE_URL=
AI_DECK_SQS_IMAGE_QUEUE_URL=
AI_DECK_SQS_QA_FINALIZE_QUEUE_URL=
LIVE_STT_PROVIDER=sherpa
LIVE_STT_ENGINE=web-speech
REPORT_STT_PROVIDER=openai
REHEARSAL_AUDIO_MAX_BYTES=25000000
OCR_PROVIDER=python
LLM_PROVIDER=openai
AI_SLIDE_IMAGE_REVIEW_MODE=auto
ORBIT_PPTX_OOXML_VECTOR_IMPORT=true

# Browser pairwise NLI remains off until a device-specific benchmark is certified.
VITE_SEMANTIC_CUE_NLI_ENABLED=false
VITE_SEMANTIC_CUE_NLI_PROVIDER=off
VITE_SEMANTIC_CUE_NLI_MODEL_ID=MoritzLaurer/multilingual-MiniLMv2-L6-mnli-xnli
VITE_SEMANTIC_CUE_NLI_BENCHMARK_PASSED=false
VITE_SEMANTIC_CUE_NLI_BENCHMARK_DEVICE=

# Browser Live STT uses LIVE_STT_ENGINE=web-speech by default for Chrome on-device Web Speech.
# Set LIVE_STT_ENGINE=openai-realtime for OpenAI Realtime STT.
# Report STT supports OpenAI or a hosted WhisperX provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_PPT_VISUAL_QA_MODEL=
OPENAI_IMAGE_MODEL=gpt-image-1
IMAGE_PROVIDER=openai
PUBLIC_IMAGE_PROVIDER=openverse
IMAGE_MAX_PER_DECK=4
IMAGE_MAX_PER_USER_PER_DAY=30
# Report STTΈΛΦ whisper-1ΉζΕ ΉΓυΉγσΊΧεΈΜν. whisper-1Ήζα verbose_json ΉζΣΈΜ╡ΈπΝ ΉΕ╕Ά╖╕Έρ╝ΊΛ╕
# ΊΔΑΉηΕΉΛνΊΔυΊΦΕΉβΑ durationΉζΕ ΉιεΆ│╡ΊΧ┤ Ά╕┤ Ή╣ρΈυ╡/Έ░εΊΣε ΉΗΞΈΠΕ(WPM) ΉπΑΊΣεΈξ╝ Ά│ΕΉΓ░ΊΧι ΉΙα ΉηΙΈΜν.
# (gpt-4o-transcribeΈΛΦ ΊΖΞΉΛνΊΛ╕ΈπΝ Έ░αΊβαΊΧ┤ ΉΜεΆ░Ε Ά╕░Έ░α ΉπΑΊΣεΆ░Α 0Ήε╝Έκε ΈΓαΉαρΈΜν.)
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_TRANSCRIPTION_DELAY=minimal
OPENAI_REALTIME_CLIENT_SECRET_TTL_SECONDS=600
WHISPERX_API_URL=
WHISPERX_API_KEY=
WHISPERX_MODEL=large-v3
WHISPERX_TIMEOUT_MS=30000

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TRANSCRIBE_LANGUAGE_CODE=ko-KR
TEXTRACT_ENABLED=false

AUTH_COOKIE_SECURE=
LOG_LEVEL=debug
LOG_PRETTY=false

DEMO_USER_ID=user_demo_1
DEMO_WORKSPACE_ID=workspace_demo_1
DEMO_PROJECT_ID=project_demo_1
DEMO_DECK_ID=deck_demo_1
DEMO_SESSION_ID=session_demo_1
