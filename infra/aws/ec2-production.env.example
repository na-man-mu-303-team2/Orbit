# ORBIT AWS production EC2 environment template.
# Store the real file at /etc/orbit/production.env on the EC2 instance.
# Keep the real file root-owned and mode 0600. Do not commit real values.

NODE_ENV=production
APP_ENV=production

WEB_PORT=5173
API_PORT=3000
WORKER_PORT=3001
PYTHON_WORKER_PORT=8000

WEB_ORIGIN=https://REPLACE_WITH_CLOUDFRONT_DOMAIN
API_BASE_URL=https://REPLACE_WITH_CLOUDFRONT_DOMAIN
PYTHON_WORKER_URL=http://python-worker:8000

DATABASE_URL=postgres://orbit:REPLACE_WITH_DB_PASSWORD@REPLACE_WITH_RDS_ENDPOINT:5432/orbit
REDIS_URL=redis://redis:6379
PRIVATE_EVIDENCE_REDIS_URL=redis://private-evidence-redis:6379

SESSION_SECRET=REPLACE_WITH_SESSION_SECRET
COOKIE_SECRET=REPLACE_WITH_COOKIE_SECRET

STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=
S3_BUCKET=REPLACE_WITH_ASSETS_BUCKET
S3_ASSETS_BUCKET=REPLACE_WITH_ASSETS_BUCKET
# Leave empty until the dedicated private-audio bucket and IAM/KMS policy are deployed.
S3_PRIVATE_AUDIO_BUCKET=
S3_REGION=ap-northeast-2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

JOB_QUEUE_DRIVER=bullmq
ASYNC_JOB_ADMISSION_MODE=accept
SLIDE_PRACTICE_ENABLED=true
SLIDE_QUESTION_GUIDES_ENABLED=true
LIVE_STT_PROVIDER=sherpa
REPORT_STT_PROVIDER=openai
REHEARSAL_AUDIO_MAX_BYTES=25000000
OCR_PROVIDER=python
LLM_PROVIDER=openai
AI_SLIDE_IMAGE_REVIEW_MODE=auto
ORBIT_PPTX_OOXML_VECTOR_IMPORT=true

OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_TRANSCRIPTION_DELAY=minimal
OPENAI_REALTIME_CLIENT_SECRET_TTL_SECONDS=600
WHISPERX_API_URL=
WHISPERX_API_KEY=
WHISPERX_MODEL=large-v3
WHISPERX_TIMEOUT_MS=30000

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TRANSCRIBE_LANGUAGE_CODE=ko-KR
TEXTRACT_ENABLED=false

AUTH_COOKIE_SECURE=true
LOG_LEVEL=info
LOG_PRETTY=false

DEMO_USER_ID=user_demo_1
DEMO_WORKSPACE_ID=workspace_demo_1
DEMO_PROJECT_ID=project_demo_1
DEMO_DECK_ID=deck_demo_1
DEMO_SESSION_ID=session_demo_1

CLOUDWATCH_LOG_GROUP=/orbit/production
